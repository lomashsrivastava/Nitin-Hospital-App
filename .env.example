# ============================================================
# .env.example — Copy to .env and fill in your values
# This file is safe to commit. Never commit the actual .env
# ============================================================

# ── MongoDB Atlas ──────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0
DB_NAME=nitin_medical

# ── Django ─────────────────────────────────────────────────
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-super-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── CORS (comma-separated list of allowed frontend URLs) ───
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend (only needed for Docker Compose local dev) ────
# In Netlify, set VITE_API_URL in Site Settings → Environment Variables
VITE_API_URL=http://localhost:8000
