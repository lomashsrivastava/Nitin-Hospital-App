{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": ["backend/**"]
  },
  "deploy": {
    "startCommand": "python manage.py migrate --noinput && gunicorn nitin_billing.wsgi:application",
    "restartPolicyType": "ON_FAILURE",
    "rootDirectory": "backend"
  }
}
